# Copy this file to ".env" and fill in your keys.
#   cp .env.example .env
# The .env file is git-ignored, so your secrets stay local.

# OpenAI (used for GPT attacker/target/judge models)
OPENAI_API_KEY=

# OpenRouter (used by the OpenRouter model class)
OPENROUTER_API_KEY=

# Google PaLM / Gemini
PALM_API_KEY=

# Self-hosted model endpoints (optional)
MODEL_API_KEY=
LLAMA_API_KEY=
VICUNA_API_KEY=
